! URXVT APPEARANCE
URxvt.font:                       xft:shuretechmono nerd font mono:size=10
URxvt.geometry:                   75x18
URxvt.internalBorder:             20
URxvt.cursorBlink:                true
URxvt.cursorUnderline:            true
URxvt.scrollBar:	          false
URxvt.saveline:                   5000
URxvt.scrollstyle:                plain
URxvt.urgentOnBell:               false
URxvt.depth:                      24
URxvt.iso14755:                   false

! Copy paste
URxvt.keysym.Shift-Control-V: eval:paste_clipboard
URxvt.keysym.Shift-Control-C: eval:selection_to_clipboard

URxvt.url-Launcher:                /usr/bin/firefox-esr
URxvt.underlineURLs:              true
URxvt.urlButton:                  1

!COLOR SCHEME
*.foreground:   #F3F3F3
*.background:   #252A34
*.cursorColor:  #29edbe

! black
*.color0:       #3B4252
*.color8:       #BDBDBD

! red
*.color1:	#F865A5
*.color9:       #EA5EBB

! green
*.color2:       #68e09b
*.color10:      #2ae077

! yellow
*.color3:       #ffb630
*.color11:      #f0a412

! blue
*.color4:       #8C8CEA
*.color12:      #5E5EEA

! magenta
*.color5:       #CB8CEA
*.color13:      #BB5EEA

! cyan
*.color6:       #64D1E0
*.color14:      #5EEAEA

! white
*.color7:       #FFFFFF
*.color15:      #F3F3F3
